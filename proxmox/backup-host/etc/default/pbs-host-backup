# Expects PBS_REPOSITORY and PBS_PASSWORD{_FD,_FILE,_CMD} to be set.
# Also set the archive:path combinations to be backed up in BACKUP_HOST_DIRS
#
# Ensure you host name in PBS_REPOSITORY matches the TLS cert in use by the
# PBS server so proxmox-backup-client will not prompt you to save fingerprints
#

PBS_REPOSITORY='root@pam!pve03Backup@pbs.example.com:NAS'
PBS_PASSWORD_FILE=/usr/local/etc/pbs-host-backup-token

BACKUP_HOST_DIRS='root.pxar:/ etc-pve.pxar:/etc/pve'

BACKUP_REPORT_EMAIL_ADDRESS=sysadmin@kraychete.com
